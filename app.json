{
  "expo": {
    "name": "pikolet",
    "slug": "pikolet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pikolet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Pikolèt utilise vos photos pour illustrer vos annonces et votre profil.",
        "NSPhotoLibraryAddUsageDescription": "Pikolèt enregistre des photos dans votre galerie.",
        "NSMicrophoneUsageDescription": "Pikolèt peut enregistrer des chants depuis votre microphone."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Pikolèt",
      "shortName": "Pikolèt",
      "description": "La communauté des éleveurs de pikolèt & lorti en Guyane",
      "themeColor": "#B85C38",
      "backgroundColor": "#FAF6F0",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Pikolèt utilise vos photos pour illustrer vos annonces et votre profil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/pikolet"
    }
  }
}
